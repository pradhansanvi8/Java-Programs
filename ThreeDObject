#include <iostream>
#include <cmath>
using namespace std;

class ThreeDObject {
public:
    virtual void surfaceArea() = 0;
    virtual void volume() = 0;
};

class Box : public ThreeDObject {
    float l, b, h;
public:
    Box(float x, float y, float z) { l=x; b=y; h=z; }
    void surfaceArea() { cout << 2*(l*b + b*h + h*l) << endl; }
    void volume() { cout << l*b*h << endl; }
};

class Cube : public ThreeDObject {
    float a;
public:
    Cube(float x) { a=x; }
    void surfaceArea() { cout << 6*a*a << endl; }
    void volume() { cout << a*a*a << endl; }
};

class Cylinder : public ThreeDObject {
    float r, h;
public:
    Cylinder(float x, float y) { r=x; h=y; }
    void surfaceArea() { cout << 2*M_PI*r*(r+h) << endl; }
    void volume() { cout << M_PI*r*r*h << endl; }
};

class Cone : public ThreeDObject {
    float r, h;
public:
    Cone(float x, float y) { r=x; h=y; }
    void surfaceArea() { cout << M_PI*r*(r + sqrt(r*r+h*h)) << endl; }
    void volume() { cout << (M_PI*r*r*h)/3 << endl; }
};

int main() {
    ThreeDObject *obj;

    obj = new Box(2,3,4);
    obj->surfaceArea(); obj->volume();

    obj = new Cube(3);
    obj->surfaceArea(); obj->volume();

    obj = new Cylinder(2,5);
    obj->surfaceArea(); obj->volume();

    obj = new Cone(2,5);
    obj->surfaceArea(); obj->volume();

    return 0;
}